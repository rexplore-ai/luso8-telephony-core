# Luso8 Telephony Core — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   nano .env
#   docker-compose -f docker/docker-compose.yml up

# =============================================================================
# ARI — Asterisk REST Interface
# These values appear in the Luso8 Cloud UI "Configure Telephony Provider" form.
# =============================================================================

# ARI username — must match [section] name in ari.conf
ARI_USERNAME=asterisk

# ARI password — use a strong random string (32+ characters) in production
# Generate one: openssl rand -base64 32
ARI_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Port the ARI HTTP server listens on (default: 8088)
ARI_PORT=8088

# IP to bind ARI to. Use 0.0.0.0 to accept all, or a specific private IP
# In production, bind to a private IP and access via VPN/VPC only
ARI_BIND_ADDR=0.0.0.0

# Stasis application name — must match what Voxtra connects to
# For multi-tenant: each tenant gets their own app name (e.g., voxtra_org_acme)
ARI_APP_NAME=voxtra

# =============================================================================
# NETWORK / NAT
# Required for Asterisk to work correctly behind a VPS/GCE NAT.
# =============================================================================

# Your server's public/external IP address
# Find it with: curl ifconfig.me
EXTERNAL_IP=YOUR_SERVER_PUBLIC_IP

# Your server's internal/private network range (for NAT bypass)
# GCE: 10.0.0.0/8  |  DigitalOcean: 10.0.0.0/8  |  Local: 192.168.0.0/16
LOCAL_NET=10.0.0.0/8

# Your Asterisk server's domain or hostname
SIP_DOMAIN=pbx.yourdomain.com

# =============================================================================
# SIP TRUNK — YOUR LOCAL CARRIER
# Get these from your local SIP provider (e.g., your Malawi carrier).
# =============================================================================

# Carrier's SIP server hostname or IP
SIP_TRUNK_HOST=sip.yourcarrier.com

# SIP port (default: 5060)
SIP_TRUNK_PORT=5060

# Your SIP account username (usually your DID/phone number)
SIP_TRUNK_USER=265XXXXXXXXX

# Your SIP account password
SIP_TRUNK_PASS=YOUR_CARRIER_PASSWORD

# SIP authentication realm (usually same as SIP_TRUNK_HOST)
SIP_TRUNK_REALM=sip.yourcarrier.com

# =============================================================================
# CALL ROUTING
# =============================================================================

# Default dialplan context for inbound calls from the carrier
DEFAULT_CONTEXT=from-carrier

# Default caller ID shown on outbound calls
OUTBOUND_CALLER_ID=+265XXXXXXXXX

# =============================================================================
# RTP MEDIA PORTS
# These UDP ports carry audio. MUST be open in your firewall.
# Port range = (RTP_PORT_END - RTP_PORT_START) / 2 = max concurrent calls
# Default range of 10000-10100 supports 50 concurrent calls.
# For 500 concurrent calls, use 10000-11000.
# =============================================================================
RTP_PORT_START=10000
RTP_PORT_END=10100

# =============================================================================
# LOGGING
# =============================================================================
# Values: debug | verbose | notice | warning | error
LOG_LEVEL=notice
